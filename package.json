{
  "name": "voidhop",
  "version": "1.1.0",
  "private": true,
  "description": "Zero-knowledge URL shortener — encrypts client-side, server stores only opaque ciphertext.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite",
    "dev:worker": "wrangler dev",
    "build": "tsc -b && vite build && node scripts/check-no-external-deps.mjs",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "oxlint src worker tests",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.95.0",
    "hono": "^4.6.0",
    "qrcode-generator": "^1.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "@playwright/test": "^1.48.0",
    "@tanstack/router-plugin": "^1.95.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "miniflare": "^3.20240925.0",
    "oxlint": "^0.10.0",
    "rolldown-vite": "^6.0.0-alpha",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.78.0"
  },
  "engines": {
    "node": ">=20"
  }
}
